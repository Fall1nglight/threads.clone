{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore.Mvc": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.AspNetCore.Hosting": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "JwtOptions": {
    "Issuer": "ThreadsApi",
    "Audience": "ThreadsFrontend",
    "ExpirationInMinutes": 5,
    "SecretKey": ""
  },
  "RefreshTokenOptions": {
    "LifetimeInDays" : 7,
    "MaxActiveTokensPerUser": 5
  },
  "AllowedHosts": "*"
}
